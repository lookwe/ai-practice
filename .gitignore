```gitignore
# Compiled and binary files
*.pyc
__pycache__/
*.class
*.o
*.exe
*.dll
*.so
*.a
*.obj
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Build and distribution
dist/
build/
target/
.gradle/

# Python specific
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so
.Pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo

# Coverage reports
coverage/
htmlcov/

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```
